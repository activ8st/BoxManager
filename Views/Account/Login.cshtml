@{
    ViewData["Title"] = "Accedi al portale";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="card p-4 p-md-5 border-0 shadow-sm" style="max-width: 450px; width: 100%; background: #ffffff; border-radius: 1rem; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05) !important;">
        <h2 class="text-center fw-bold mb-4" style="color: #0f172a; font-size: 1.75rem;">Accedi al portale</h2>
        
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
            
            <div class="mb-3">
                <label class="form-label text-muted small fw-medium" style="font-size: 0.75rem;">Email</label>
                <div class="input-group border-bottom border-1 pb-1 align-items-center">
                    <span class="input-group-text bg-transparent border-0 px-0 text-muted me-2"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="email" class="form-control bg-transparent border-0 p-0" placeholder="indirizzo e-mail" required style="box-shadow: none; font-size: 0.95rem;" />
                </div>
            </div>
            
            <div class="mb-4">
                <label class="form-label text-muted small fw-medium" style="font-size: 0.75rem;">Password</label>
                <div class="input-group border-bottom border-1 pb-1 align-items-center">
                    <span class="input-group-text bg-transparent border-0 px-0 text-muted me-2"><i class="bi bi-lock"></i></span>
                    <input type="password" name="password" id="loginPassword" class="form-control bg-transparent border-0 p-0" placeholder="Password" style="box-shadow: none; font-size: 0.95rem;" />
                    <button class="btn bg-transparent border-0 p-0 text-muted" type="button" onclick="togglePasswordVisibility()">
                        <i class="bi bi-eye-slash" id="toggleIcon"></i>
                    </button>
                </div>
            </div>
            
            <div class="d-flex align-items-center justify-content-between mb-4" style="font-size: 0.8rem;">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="rememberMe" />
                    <label class="form-check-label text-muted" for="rememberMe">Ricordami</label>
                </div>
                <a href="#" class="text-decoration-none text-muted" onclick="alert('Demo: per accedere come cliente inserisci una delle email dei referenti (es: v.ferrari@outlook.com), come fornitore inserisci admin@boxmanager.it. Qualsiasi password è accettata.')">Password dimenticata?</a>
            </div>
            
            <button type="submit" class="btn btn-primary w-100 py-2.5 mb-4" style="background-color: #0d6efd; border: none; font-weight: 500; border-radius: 0.5rem; font-size: 0.95rem; box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);">
                Accedi
            </button>
            

        </form>
    </div>
</div>

<script>
    function togglePasswordVisibility() {
        const passwordInput = document.getElementById("loginPassword");
        const toggleIcon = document.getElementById("toggleIcon");
        if (passwordInput.type === "password") {
            passwordInput.type = "text";
            toggleIcon.classList.remove("bi-eye-slash");
            toggleIcon.classList.add("bi-eye");
        } else {
            passwordInput.type = "password";
            toggleIcon.classList.remove("bi-eye");
            toggleIcon.classList.add("bi-eye-slash");
        }
    }
</script>
