@model BoxManager.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card card-stat card-stat-level-1 h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">Ordini Totali</h6>
                <h3 class="fw-bold mb-0">@Model.TotalOrders</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stat card-stat-level-1 h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">Clienti Attivi</h6>
                <h3 class="fw-bold mb-0">@Model.ActiveCustomers</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stat card-stat-level-1 h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">Fatturato Stimato</h6>
                <h3 class="fw-bold mb-0">€ @Model.EstimatedRevenue.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stat card-stat-level-1 h-100">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small">In Produzione</h6>
                <h3 class="fw-bold mb-0">@Model.OrdersInProduction</h3>
            </div>
        </div>
    </div>
</div>

<div class="row" id="dashboardApp">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Ultimi Ordini</h5>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-primary">Vedi tutti</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Data</th>
                                <th>Cliente</th>
                                <th>Codice</th>
                                <th>Stato</th>
                                <th style="text-align:right; white-space:nowrap;">Totale</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                var displayName = order.Status switch
                                {
                                    BoxManager.Models.OrderStatus.Pending      => "In attesa",
                                    BoxManager.Models.OrderStatus.InProduction  => "In produzione",
                                    BoxManager.Models.OrderStatus.Completed     => "Completato",
                                    BoxManager.Models.OrderStatus.Delivered     => "Consegnato",
                                    BoxManager.Models.OrderStatus.Cancelled     => "Annullato",
                                    _ => order.Status.ToString()
                                };

                                var statusBadgeClass = order.Status switch
                                {
                                    BoxManager.Models.OrderStatus.Pending      => "order-status-badge order-status-badge--pending",
                                    BoxManager.Models.OrderStatus.InProduction  => "order-status-badge order-status-badge--inproduction",
                                    BoxManager.Models.OrderStatus.Completed     => "order-status-badge order-status-badge--completed",
                                    BoxManager.Models.OrderStatus.Delivered     => "order-status-badge order-status-badge--delivered",
                                    BoxManager.Models.OrderStatus.Cancelled     => "order-status-badge order-status-badge--cancelled",
                                    _ => "order-status-badge"
                                };

                                <tr style="cursor:pointer;" onclick="window.location.href='@Url.Action("Details", "Orders", new { id = order.Id })'">
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td>@order.Customer.BusinessName</td>
                                    <td>@order.BoxCode</td>
                                    <td>
                                        <span class="@statusBadgeClass">@displayName</span>
                                    </td>
                                    <td style="text-align:right; white-space:nowrap;">€ @order.TotalPrice.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Ricerca Rapida Clienti</h5>
            </div>
            <div class="card-body">
                <div class="position-relative mb-3">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="pointer-events:none;"></i>
                    <input type="text"
                           class="form-control ps-5"
                           placeholder="Cerca cliente..."
                           v-model="searchQuery"
                           v-on:keyup.enter="searchCustomers">
                </div>
                <div class="list-group list-group-flush">
                    @foreach (var customer in Model.Customers)
                    {
                        <a asp-controller="Customers" asp-action="Details" asp-route-id="@customer.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            @customer.BusinessName
                            <i class="bi bi-chevron-right small text-muted"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const { createApp } = Vue;
        createApp({
            data() {
                return {
                    searchQuery: ''
                }
            },
            methods: {
                searchCustomers() {
                    if (this.searchQuery.trim()) {
                        window.location.href = `/Customers?searchString=${encodeURIComponent(this.searchQuery)}`;
                    }
                }
            }
        }).mount('#dashboardApp');
    </script>
}
