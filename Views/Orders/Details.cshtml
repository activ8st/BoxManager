@model BoxManager.Models.Order
@{
    ViewData["Title"] = "Dettaglio Ordine #" + Model.Id;
}

@{
    var sheet = Model.TechnicalSheet;
    var customer = Model.Customer;
}

<div class="card shadow-sm mb-4 border-0">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <nav aria-label="breadcrumb" class="mb-2">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-controller="Orders" asp-action="Index">Ordini</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@($"ORD-{Model.OrderDate:yyyy}-{Model.Id:D3}")</li>
                    </ol>
                </nav>
                <h2 class="fw-bold mb-1">@($"ORD-{Model.OrderDate:yyyy}-{Model.Id:D3}")</h2>
                <p class="text-muted mb-1">Data: @Model.OrderDate.ToString("dd/MM/yyyy")</p>
            </div>

            <div class="d-flex gap-2 align-items-center">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" class="btn btn-outline-secondary me-2"><i class="bi bi-pencil me-1"></i>Modifica</a>
                    string? actionText = null;
                    BoxManager.Models.OrderStatus? actionStatus = null;

                    if (Model.Status == BoxManager.Models.OrderStatus.Pending)
                    {
                        actionText = "Avvia Produzione »";
                        actionStatus = BoxManager.Models.OrderStatus.InProduction;
                    }
                    else if (Model.Status == BoxManager.Models.OrderStatus.InProduction)
                    {
                        actionText = "Completa »";
                        actionStatus = BoxManager.Models.OrderStatus.Completed;
                    }
                    else if (Model.Status == BoxManager.Models.OrderStatus.Completed)
                    {
                        actionText = "Conferma Consegna »";
                        actionStatus = BoxManager.Models.OrderStatus.Delivered;
                    }

                    @if (actionText != null && actionStatus.HasValue)
                    {
                        <button id="startProductionBtn" class="btn btn-primary" onclick="updateStatus('@actionStatus')">@actionText</button>
                    }
                }
            </div>
        </div>

        <!-- Second row: three summary cards -->
        <div class="d-flex justify-content-center gap-3 mt-3 flex-wrap">
            <div class="card border shadow-sm p-3 text-center" style="min-width: 10rem;">
                <div class="text-muted small">Quantità</div>
                <div class="h4 fw-bold mb-0">@Model.Quantity</div>
            </div>
            <div class="card border shadow-sm p-3 text-center" style="min-width: 10rem;">
                <div class="text-muted small">Totale</div>
                <div class="h4 fw-bold mb-0">€ @Model.TotalPrice.ToString("N2")</div>
            </div>
            <div class="card border shadow-sm p-3 text-center" style="min-width: 10rem;">
                <div class="text-muted small">Codice FEFCO</div>
                <div class="h4 fw-bold mb-0">@(sheet?.FefcoCode ?? "—")</div>
            </div>
        </div>

        <!-- Third row: stepper -->
        <div class="d-flex justify-content-center mt-4">
            @{
                var statuses = new[] {
                    Tuple.Create("In Attesa", BoxManager.Models.OrderStatus.Pending),
                    Tuple.Create("In Produzione", BoxManager.Models.OrderStatus.InProduction),
                    Tuple.Create("Completato", BoxManager.Models.OrderStatus.Completed),
                    Tuple.Create("Consegnato", BoxManager.Models.OrderStatus.Delivered)
                };
                var current = Model.Status;
                var currentIndex = Array.FindIndex(statuses, s => s.Item2 == current);
                // Percentuale della linea colorata: da primo a ultimo pallino (non oltre i bordi)
                // Con 4 step: 0%=0, 1=33%, 2=66%, 3=100%
                var linePercent = currentIndex < 0 ? 0 : (int)Math.Round(currentIndex / (double)(statuses.Length - 1) * 100);
            }
            <div class="stepper" style="max-width:720px; width:100%;">
                <div class="line"></div>
                <div class="line-progress" id="stepperProgress" style="width: 0%;" data-target="@(linePercent)"></div>
                <ul class="list-unstyled d-flex mb-0">
                    @for (int i = 0; i < statuses.Length; i++)
                    {
                        var item = statuses[i];
                        var isCurrent = current == item.Item2;
                        var isDone = i <= currentIndex;
                        <li class="text-center" style="flex:1;">
                            <div class="circle @(isCurrent ? "active" : isDone ? "done" : "")">&nbsp;</div>
                            <div class="small mt-1 @(isDone ? "text-primary fw-medium" : "text-muted")">@item.Item1</div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Customer Info and Tabs -->
<div class="row">
    <div class="col-lg-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white fw-bold">Cliente</div>
            <div class="card-body">
                <h5 class="fw-bold text-primary mb-2">@(customer?.BusinessName ?? "—")</h5>
                <p class="mb-2"><i class="bi bi-geo-alt me-2"></i>@(customer?.Address ?? "—")</p>
                <p class="mb-2"><i class="bi bi-envelope me-2"></i>@(customer?.Email ?? "—")</p>
                <p class="mb-2"><i class="bi bi-telephone me-2"></i>@(customer?.Phone ?? "—")</p>
                <p class="mb-0"><i class="bi bi-person me-2"></i>@(customer?.ContactPerson ?? "—")</p>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
            <style>
                .custom-tabs { border-bottom: 2px solid #e5e7eb; gap: 0.5rem; }
                .custom-tabs .nav-link { 
                    border: 2px solid transparent; 
                    border-bottom: none; 
                    color: #6b7280; 
                    font-weight: 500; 
                    padding: 0.75rem 1.5rem; 
                    border-radius: 0.5rem 0.5rem 0 0; 
                    margin-bottom: -2px; 
                    transition: all 0.2s;
                }
                .custom-tabs .nav-link:hover { border-color: #e5e7eb; border-bottom: none; color: #374151; background: #f9fafb; }
                .custom-tabs .nav-link.active { 
                    border-color: #e5e7eb; 
                    border-bottom: 2px solid #fff; 
                    color: #0d6efd; 
                    font-weight: 600; 
                    background: #fff; 
                }
            </style>
            <div class="card-header bg-white pt-3 px-4 border-0 pb-0">
                <ul class="nav nav-tabs custom-tabs" id="orderTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="struttura-tab" data-bs-toggle="tab" data-bs-target="#struttura" type="button" role="tab">Struttura</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="stampa-tab" data-bs-toggle="tab" data-bs-target="#stampa" type="button" role="tab">Stampa</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="economici-tab" data-bs-toggle="tab" data-bs-target="#economici" type="button" role="tab">Aspetti Economici</button>
                    </li>
                </ul>
            </div>
            <div class="card-body pt-4">
                <div class="tab-content">

                    <!-- TAB: Struttura -->
                    <div class="tab-pane fade show active" id="struttura" role="tabpanel">
                        <div class="row mb-4">
                            <div class="col-md-4 mb-3">
                                <div class="p-3 bg-light rounded text-center">
                                    <small class="text-muted d-block">Lunghezza (MM)</small>
                                    <div class="h5 fw-bold">@((sheet != null) ? $"{sheet.Length} mm" : "—")</div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="p-3 bg-light rounded text-center">
                                    <small class="text-muted d-block">Larghezza (MM)</small>
                                    <div class="h5 fw-bold">@((sheet != null) ? $"{sheet.Width} mm" : "—")</div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="p-3 bg-light rounded text-center">
                                    <small class="text-muted d-block">Altezza (MM)</small>
                                    <div class="h5 fw-bold">@((sheet != null) ? $"{sheet.Height} mm" : "—")</div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <p class="small text-muted mb-1">Tipologia Cartone</p>
                                <div class="fw-bold">@(sheet?.CardboardType ?? "—")</div>
                            </div>
                            <div class="col-md-4">
                                <p class="small text-muted mb-1">Tipo Onda</p>
                                <div class="fw-bold">@(sheet?.WaveType ?? "—")</div>
                            </div>
                            <div class="col-md-4">
                                <p class="small text-muted mb-1">Codice FEFCO</p>
                                <div><span class="badge bg-dark text-white">@(sheet?.FefcoCode ?? "—")</span></div>
                            </div>
                        </div>
                    </div>

                    <!-- TAB: Stampa -->
                    <div class="tab-pane fade" id="stampa" role="tabpanel">
                        @if (sheet != null)
                        {
                            <div class="row mb-3">
                                <div class="col-md-3 mb-3">
                                    <p class="small text-muted mb-1">Stampa</p>
                                    <div class="fw-bold">@(sheet.HasPrinting ? "Sì" : "No")</div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <p class="small text-muted mb-1">Tipologia</p>
                                    <div class="fw-bold">@(sheet?.PrintingType ?? "—")</div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <p class="small text-muted mb-1">Colori</p>
                                    <div class="fw-bold">@(sheet?.ColorCount ?? 0)</div>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <p class="small text-muted mb-1">Finiture</p>
                                    <div class="fw-bold">@(sheet?.SpecialFinishes ?? "—")</div>
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(sheet?.ColorCodes))
                            {
                                var codes = sheet.ColorCodes.Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries)
                                    .Select(c => c.Trim()).Where(c => c.Length > 0).ToArray();
                                if (codes.Length > 0)
                                {
                                    <div class="mb-3">
                                        <p class="small text-muted mb-1">Palette colori</p>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var code in codes)
                                            {
                                                <span class="color-swatch" title="@code" style="background:@code"></span>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <p class="small text-muted mb-1">Logo Cliente</p>
                                    @if (!string.IsNullOrWhiteSpace(sheet?.CustomerLogoPath))
                                    {
                                        <img src="@sheet.CustomerLogoPath" alt="Logo cliente" class="img-fluid rounded border" style="max-height: 140px;" />
                                    }
                                    else
                                    {
                                        <div class="text-muted">Nessun logo caricato</div>
                                    }
                                </div>
                                <div class="col-md-6 mb-3">
                                    <p class="small text-muted mb-1">Note Stampa</p>
                                    <div class="fw-normal">@(string.IsNullOrWhiteSpace(sheet?.PrintingNotes) ? "Nessuna nota" : sheet.PrintingNotes)</div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted fst-italic">Scheda tecnica non disponibile per questo ordine.</p>
                        }
                    </div>

                    <!-- TAB: Aspetti Economici -->
                    <div class="tab-pane fade" id="economici" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Quantità</th>
                                        <th>Prezzo Unitario</th>
                                        <th>Sconto</th>
                                        <th class="text-end">Totale Ordine</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>@Model.Quantity pz</td>
                                        <td>€ @(sheet != null ? sheet.UnitPrice.ToString("N2") : "0.00")</td>
                                        <td>@(sheet != null ? sheet.Discount.ToString() : "0") %</td>
                                        <td class="text-end fw-bold h5 text-primary">€ @Model.TotalPrice.ToString("N2")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .stepper { position: relative; padding: 1rem 0 0.5rem 0; }
    .stepper .line { position:absolute; left:0; right:0; top:18px; height:3px; background:#e9ecef; z-index:0; }
    .stepper .line-progress { position:absolute; left:0; top:18px; height:3px; background:#0d6efd; z-index:1; transition: width 0.9s ease; }
    .stepper ul { position:relative; z-index:2; display:flex; justify-content:space-between; align-items:center; padding:0; margin:0; list-style:none; }
    .stepper ul li { text-align:center; }
    .stepper .circle { width:28px; height:28px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:12px; border:1px solid #ced4da; background:#fff; color:#6c757d; transition: all 0.3s; }
    .stepper .circle.done { background:#0d6efd; color:#fff; border-color:#0d6efd; }
    .stepper .circle.active { background:#0d6efd; color:#fff; border-color:#0d6efd; box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.15); }
    .color-swatch { width: 28px; height: 28px; border-radius: 50%; display: inline-block; border: 1px solid #ced4da; }

    @@media print {
        .btn-group, nav, header, footer { display: none !important; }
        .card { border: 1px solid #000 !important; box-shadow: none !important; }
        body { background: white !important; }
    }
</style>

<script>
    window.addEventListener('DOMContentLoaded', () => {
        const bar = document.getElementById('stepperProgress');
        if (bar) {
            const target = bar.getAttribute('data-target');
            requestAnimationFrame(() => { setTimeout(() => { bar.style.width = target + '%'; }, 80); });
        }
    });

    async function updateStatus(status) {
        const id = '@Model.Id';
        try {
            const form = new URLSearchParams();
            form.append('id', id);
            form.append('status', status);

            const resp = await fetch('/Orders/UpdateStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: form.toString()
            });
            if (resp.ok) {
                location.reload();
            } else if (resp.status === 403) {
                alert('Permesso negato: operazione riservata agli amministratori.');
            } else {
                const txt = await resp.text();
                alert('Errore aggiornamento stato: ' + resp.status + '\n' + txt);
            }
        } catch (ex) {
            console.error(ex);
            alert('Errore di rete durante l\'aggiornamento dello stato.');
        }
    }
</script>
