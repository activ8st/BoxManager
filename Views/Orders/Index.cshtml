@model IEnumerable<BoxManager.Models.Order>
@{
    ViewData["Title"] = "Gestione Ordini";
    var currentStatusFilter = ViewBag.CurrentStatusFilter as string;
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <div>
        <h2 class="fw-bold text-dark mb-0" style="font-size: 1.75rem;">Ordini</h2>
        <p class="text-muted mb-0" style="font-size: 0.9rem;">@ViewBag.TotalCount ordini totali</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-outline-dark rounded-pill px-3 py-2 d-flex align-items-center bg-white shadow-sm fw-medium" style="font-size: 0.85rem;"><span class="me-2">Nuovo ordine</span> <i class="bi bi-plus-lg fs-6"></i></a>
    }
</div>

<div class="d-flex flex-wrap gap-2 mb-4 align-items-center justify-content-between">
    <!-- Status Filter Tabs -->
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-sm rounded-pill px-3 py-1.5 d-flex align-items-center @(string.IsNullOrEmpty(currentStatusFilter) ? "btn-primary text-white shadow-sm" : "bg-white text-secondary border shadow-sm")" href="/Orders">
            Tutti <span class="badge rounded-circle bg-light text-dark ms-2" style="font-size: 0.75rem; padding: 0.35em 0.6em;">@ViewBag.TotalCount</span>
        </a>
        <a class="btn btn-sm rounded-pill px-3 py-1.5 d-flex align-items-center @(currentStatusFilter == "Pending" ? "btn-primary text-white shadow-sm" : "bg-white text-secondary border shadow-sm")" href="/Orders?statusFilter=Pending">
            In attesa <span class="badge rounded-circle bg-light text-dark ms-2" style="font-size: 0.75rem; padding: 0.35em 0.6em;">@ViewBag.PendingCount</span>
        </a>
        <a class="btn btn-sm rounded-pill px-3 py-1.5 d-flex align-items-center @(currentStatusFilter == "InProduction" ? "btn-primary text-white shadow-sm" : "bg-white text-secondary border shadow-sm")" href="/Orders?statusFilter=InProduction">
            In corso <span class="badge rounded-circle bg-light text-dark ms-2" style="font-size: 0.75rem; padding: 0.35em 0.6em;">@ViewBag.InProductionCount</span>
        </a>
        <a class="btn btn-sm rounded-pill px-3 py-1.5 d-flex align-items-center @(currentStatusFilter == "Completed" ? "btn-primary text-white shadow-sm" : "bg-white text-secondary border shadow-sm")" href="/Orders?statusFilter=Completed">
            Pronto <span class="badge rounded-circle bg-light text-dark ms-2" style="font-size: 0.75rem; padding: 0.35em 0.6em;">@ViewBag.CompletedCount</span>
        </a>
        <a class="btn btn-sm rounded-pill px-3 py-1.5 d-flex align-items-center @(currentStatusFilter == "Delivered" ? "btn-primary text-white shadow-sm" : "bg-white text-secondary border shadow-sm")" href="/Orders?statusFilter=Delivered">
            Consegnato <span class="badge rounded-circle bg-light text-dark ms-2" style="font-size: 0.75rem; padding: 0.35em 0.6em;">@ViewBag.DeliveredCount</span>
        </a>
    </div>
    
    <!-- Search Box -->
    <form asp-action="Index" method="get" class="d-flex align-items-center" style="max-width: 300px; width: 100%;">
        @if (!string.IsNullOrEmpty(currentStatusFilter))
        {
            <input type="hidden" name="statusFilter" value="@currentStatusFilter" />
        }
        <div class="input-group input-group-sm bg-white rounded-pill border px-2 py-1 shadow-sm w-100 align-items-center">
            <span class="input-group-text bg-transparent border-0 text-muted p-0 me-2"><i class="bi bi-search"></i></span>
            <input type="text" name="searchString" class="form-control border-0 bg-transparent p-0" placeholder="Cerca ordine, cliente, cod..." value="@ViewBag.CurrentFilter" style="box-shadow: none; font-size: 0.85rem;" />
        </div>
    </form>
</div>

<div class="card shadow-sm border-0 rounded-3" id="ordersApp">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280;">
                        <th class="ps-4">ID Ordine</th>
                        @if (User.IsInRole("Admin")) { <th>Cliente</th> }
                        <th>Referente</th>
                        <th>Codice Scatola</th>
                        <th>Codice Fefco</th>
                        <th>Data</th>
                        <th>Stato</th>
                        @if (User.IsInRole("Admin")) { <th class="pe-4 text-end">Azioni</th> }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var displayName = item.Status switch
                        {
                            BoxManager.Models.OrderStatus.Pending => "In attesa",
                            BoxManager.Models.OrderStatus.InProduction => "In corso",
                            BoxManager.Models.OrderStatus.Completed => "Pronto",
                            BoxManager.Models.OrderStatus.Delivered => "Consegnato",
                            BoxManager.Models.OrderStatus.Cancelled => "Annullato",
                            _ => item.Status.ToString()
                        };

                        var dotColor = item.Status switch
                        {
                            BoxManager.Models.OrderStatus.Pending => "text-warning",
                            BoxManager.Models.OrderStatus.InProduction => "text-success",
                            BoxManager.Models.OrderStatus.Completed => "text-primary",
                            BoxManager.Models.OrderStatus.Cancelled => "text-danger",
                            _ => "text-secondary"
                        };

                        <tr id="order-row-@item.Id">
                            <td class="ps-4 fw-medium text-secondary" style="font-size: 0.9rem;">ORD-2026-@item.Id.ToString("D3")</td>
                            @if (User.IsInRole("Admin")) { <td class="fw-bold text-dark">@item.Customer.BusinessName</td> }
                            <td class="text-dark fw-medium" style="font-size: 0.9rem;">@item.Referente</td>
                            <td class="text-secondary" style="font-size: 0.9rem;">@item.BoxCode</td>
                            <td class="text-secondary" style="font-size: 0.9rem;">Fefco @((item.Id % 5) + 1)</td>
                            <td style="font-size: 0.9rem;" class="text-secondary">@item.OrderDate.ToString("dd/MM/yy")</td>
                            <td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <select class="form-select form-select-sm status-selector py-1 px-2 border" 
                                            data-order-id="@item.Id"
                                            onchange="updateOrderStatus(@item.Id, this.value)"
                                            style="width: 130px; font-size: 0.85rem; border-radius: 0.375rem;">
                                        @foreach (var status in Enum.GetValues(typeof(BoxManager.Models.OrderStatus)))
                                        {
                                            var optName = status switch
                                            {
                                                BoxManager.Models.OrderStatus.Pending => "In attesa",
                                                BoxManager.Models.OrderStatus.InProduction => "In corso",
                                                BoxManager.Models.OrderStatus.Completed => "Pronto",
                                                BoxManager.Models.OrderStatus.Delivered => "Consegnato",
                                                BoxManager.Models.OrderStatus.Cancelled => "Annullato",
                                                _ => status.ToString()
                                            };
                                            <!option value="@status" @(item.Status.ToString() == status.ToString() ? "selected" : "")>@optName</!option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <span style="font-size: 0.85rem; font-weight: 500;" class="text-dark">
                                        <i class="bi bi-circle-fill @dotColor me-2" style="font-size: 0.5rem; vertical-align: middle;"></i>@displayName
                                    </span>
                                }
                            </td>
                            @if (User.IsInRole("Admin")) {
                                <td class="pe-4 text-end">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border" title="Dettagli" style="border-radius: 0.375rem;"><i class="bi bi-file-earmark-text me-1"></i>Dettagli</a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/orderHub")
            .build();

        connection.on("ReceiveStatusUpdate", function (orderId, newStatus) {
            const selector = document.querySelector(`.status-selector[data-order-id="${orderId}"]`);
            if (selector) {
                selector.value = newStatus;
                selector.classList.add('is-valid');
                setTimeout(() => selector.classList.remove('is-valid'), 2000);
            } else {
                // Se non c'è il selettore (è un cliente), ricarichiamo la pagina per aggiornare il badge
                window.location.reload();
            }
        });

        connection.on("ReceiveNewOrder", function (orderId) {
            console.log("Nuovo ordine ricevuto: " + orderId);
            // Notifica real-time o reload della lista
            setTimeout(() => window.location.reload(), 1000);
        });

        connection.start().catch(err => console.error(err.toString()));

        function updateOrderStatus(orderId, status) {
            fetch(`/Orders/UpdateStatus`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `id=${orderId}&status=${status}`
            }).then(response => {
                if (response.ok) {
                    console.log("Status aggiornato");
                }
            });
        }
    </script>
}

