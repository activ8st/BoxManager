@model IEnumerable<BoxManager.Models.Order>
@{
    ViewData["Title"] = "Gestione Ordini";
    var currentStatusFilter = ViewBag.CurrentStatusFilter as string;
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <div>
        <h2 class="fw-bold text-dark mb-0" style="font-size: 1.75rem;">Ordini</h2>
        <p class="text-muted mb-0" style="font-size: 0.9rem;">@ViewBag.TotalCount ordini totali</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-2"></i>Nuovo ordine</a>
    }
</div>

<div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
    <a class="filter-pill @(string.IsNullOrEmpty(currentStatusFilter) ? "filter-pill--active" : "")" href="/Orders">
        Tutti
        <span class="filter-pill__badge filter-pill__badge--all">@ViewBag.TotalCount</span>
    </a>
    <a class="filter-pill @(currentStatusFilter == "Pending" ? "filter-pill--active filter-pill--pending-active" : "filter-pill--pending")" href="/Orders?statusFilter=Pending">
        In attesa
        <span class="filter-pill__badge filter-pill__badge--pending">@ViewBag.PendingCount</span>
    </a>
    <a class="filter-pill @(currentStatusFilter == "InProduction" ? "filter-pill--active filter-pill--inproduction-active" : "filter-pill--inproduction")" href="/Orders?statusFilter=InProduction">
        In produzione
        <span class="filter-pill__badge filter-pill__badge--inproduction">@ViewBag.InProductionCount</span>
    </a>
    <a class="filter-pill @(currentStatusFilter == "Completed" ? "filter-pill--active filter-pill--completed-active" : "filter-pill--completed")" href="/Orders?statusFilter=Completed">
        Completato
        <span class="filter-pill__badge filter-pill__badge--completed">@ViewBag.CompletedCount</span>
    </a>
    <a class="filter-pill @(currentStatusFilter == "Delivered" ? "filter-pill--active filter-pill--delivered-active" : "filter-pill--delivered")" href="/Orders?statusFilter=Delivered">
        Consegnato
        <span class="filter-pill__badge filter-pill__badge--delivered">@ViewBag.DeliveredCount</span>
    </a>
    <a class="filter-pill @(currentStatusFilter == "Cancelled" ? "filter-pill--active filter-pill--cancelled-active" : "filter-pill--cancelled")" href="/Orders?statusFilter=Cancelled">
        Annullato
        <span class="filter-pill__badge filter-pill__badge--cancelled">@ViewBag.CancelledCount</span>
    </a>
</div>

<div class="card shadow-sm border-0 rounded-3" id="ordersApp">
    <div class="card-body">
        <form asp-action="Index" method="get" class="mb-4">
            @if (!string.IsNullOrEmpty(currentStatusFilter))
            {
                <input type="hidden" name="statusFilter" value="@currentStatusFilter" />
            }
            <div class="position-relative">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="pointer-events:none;"></i>
                <input type="text"
                       name="searchString"
                       class="form-control ps-5"
                       placeholder="Cerca per ordine, cliente, codice scatola..."
                       value="@ViewBag.CurrentFilter" />
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280;">
                        <th class="ps-4">ID Ordine</th>
                        @if (User.IsInRole("Admin")) { <th>Cliente</th> }
                        <th>Referente</th>
                        <th>Codice Scatola</th>
                        <th>Codice Fefco</th>
                        <th>Data</th>
                        <th>Stato</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var displayName = item.Status switch
                        {
                            BoxManager.Models.OrderStatus.Pending      => "In attesa",
                            BoxManager.Models.OrderStatus.InProduction  => "In produzione",
                            BoxManager.Models.OrderStatus.Completed     => "Completato",
                            BoxManager.Models.OrderStatus.Delivered     => "Consegnato",
                            BoxManager.Models.OrderStatus.Cancelled     => "Annullato",
                            _ => item.Status.ToString()
                        };

                        var statusBadgeClass = item.Status switch
                        {
                            BoxManager.Models.OrderStatus.Pending      => "order-status-badge order-status-badge--pending",
                            BoxManager.Models.OrderStatus.InProduction  => "order-status-badge order-status-badge--inproduction",
                            BoxManager.Models.OrderStatus.Completed     => "order-status-badge order-status-badge--completed",
                            BoxManager.Models.OrderStatus.Delivered     => "order-status-badge order-status-badge--delivered",
                            BoxManager.Models.OrderStatus.Cancelled     => "order-status-badge order-status-badge--cancelled",
                            _ => "order-status-badge"
                        };

                        <tr style="cursor:pointer;" onclick="window.location.href='@Url.Action("Details", "Orders", new { id = item.Id })'">
                            <td class="ps-4 fw-bold text-dark" style="font-size: 0.9rem;">ORD-2026-@item.Id.ToString("D3")</td>
                            @if (User.IsInRole("Admin")) { <td class="fw-bold text-dark">@item.Customer.BusinessName</td> }
                            <td class="text-muted" style="font-size: 0.85rem;">@item.Referente</td>
                            <td class="text-muted" style="font-size: 0.85rem;">@item.BoxCode</td>
                            <td class="text-muted" style="font-size: 0.85rem;">Fefco @((item.Id % 5) + 1)</td>
                            <td class="text-muted" style="font-size: 0.85rem;">@item.OrderDate.ToString("dd/MM/yyyy")</td>
                            <td><span class="@statusBadgeClass">@displayName</span></td>
                            <td class="text-end pe-3">
                                <a asp-action="Details" asp-controller="Orders" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-light border"
                                   style="border-radius: 0.375rem; padding: 0.2rem 0.5rem;"
                                   onclick="event.stopPropagation();">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/orderHub")
            .build();

        connection.on("ReceiveStatusUpdate", function (orderId, newStatus) {
            const selector = document.querySelector(`.status-selector[data-order-id="${orderId}"]`);
            if (selector) {
                selector.value = newStatus;
                selector.classList.add('is-valid');
                setTimeout(() => selector.classList.remove('is-valid'), 2000);
            } else {
                window.location.reload();
            }
        });

        connection.on("ReceiveNewOrder", function (orderId) {
            console.log("Nuovo ordine ricevuto: " + orderId);
            setTimeout(() => window.location.reload(), 1000);
        });

        connection.start().catch(err => console.error(err.toString()));

        function updateOrderStatus(orderId, status) {
            fetch(`/Orders/UpdateStatus`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `id=${orderId}&status=${status}`
            }).then(response => {
                if (response.ok) {
                    console.log("Status aggiornato");
                }
            });
        }
    </script>
}
