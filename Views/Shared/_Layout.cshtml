@inject BoxManager.Data.ApplicationDbContext DbContext
@{
    int pendingOrdersCount = 0;
    string userInitials = "AM";
    string userRoleDisplayName = "Venditore";
    
    if (User?.Identity?.IsAuthenticated ?? false)
    {
        var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
        var ordersQuery = DbContext.Orders.AsQueryable();
        
        if (role == "Customer")
        {
            userRoleDisplayName = "Cliente";
            var customerIdClaim = User.FindFirst("CustomerId")?.Value;
            if (customerIdClaim != null && int.TryParse(customerIdClaim, out int customerId))
            {
                ordersQuery = ordersQuery.Where(o => o.CustomerId == customerId);
            }
        }
        else
        {
            userRoleDisplayName = "Fornitore";
        }
        
        pendingOrdersCount = ordersQuery.Count(o => o.Status == BoxManager.Models.OrderStatus.Pending);
        
        var name = User.Identity.Name ?? "";
        if (name == "Admin")
        {
            userInitials = "AM";
        }
        else
        {
            var parts = name.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 2)
            {
                userInitials = (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
            }
            else if (parts.Length == 1 && parts[0].Length >= 2)
            {
                userInitials = parts[0].Substring(0, 2).ToUpper();
            }
            else if (parts.Length == 1 && parts[0].Length == 1)
            {
                userInitials = parts[0].ToUpper();
            }
            else
            {
                userInitials = "CL";
            }
        }
    }
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BoxManager</title>
    <script>
        (function() {
            var theme = localStorage.getItem('theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <style>
        .card-stat { border-left: 4px solid #808080 !important; transition: transform .2s; }
        .card-stat:hover { transform: translateY(-5px); }
        .status-badge { font-size: 0.85rem; }
        .sidebar-brand { transition: opacity 0.15s ease; }
        .sidebar-brand:hover { opacity: 0.85; }
    </style>
</head>
<body class="bg-light">
    <div class="app-wrapper">
        <!-- Mobile Header Bar -->
        <div class="mobile-header d-md-none d-flex justify-content-between align-items-center">
            <a class="navbar-brand fw-bold text-white d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <i class="bi bi-box-seam me-2"></i>BoxManager
            </a>
            <button class="navbar-toggler btn text-white border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mobileMenu" aria-controls="mobileMenu" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list fs-3"></i>
            </button>
        </div>
        
        <!-- Mobile Navigation Menu (Collapsible) -->
        <div class="collapse d-md-none px-3 py-2" id="mobileMenu" style="background-color: var(--sidebar-bg); border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
            <nav class="nav nav-pills flex-column sidebar-nav p-0">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <a class="nav-link d-flex align-items-center justify-content-between mb-2 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <span><i class="bi bi-grid-fill me-3"></i>Dashboard</span>
                        <i class="bi bi-chevron-right small opacity-50"></i>
                    </a>
                    
                    if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link d-flex align-items-center justify-content-between mb-2 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Customers" ? "active" : "")" asp-controller="Customers" asp-action="Index">
                            <span><i class="bi bi-people-fill me-3"></i>Clienti</span>
                            <i class="bi bi-chevron-right small opacity-50"></i>
                        </a>
                    }
                    <a class="nav-link d-flex align-items-center justify-content-between mb-2 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Orders" ? "active" : "")" asp-controller="Orders" asp-action="Index">
                        <span><i class="bi bi-cart-fill me-3"></i>Ordini</span>
                        <span class="d-flex align-items-center">
                            @if (pendingOrdersCount > 0)
                            {
                                <span class="badge bg-warning text-dark me-2">@pendingOrdersCount</span>
                            }
                            <i class="bi bi-chevron-right small opacity-50"></i>
                        </span>
                    </a>
                }
                else
                {
                    <a class="nav-link d-flex align-items-center justify-content-between disabled opacity-50" style="pointer-events: none;">
                        <span><i class="bi bi-grid-fill me-3"></i>Dashboard</span>
                        <i class="bi bi-chevron-right small opacity-30"></i>
                    </a>
                    <a class="nav-link d-flex align-items-center justify-content-between disabled opacity-50" style="pointer-events: none;">
                        <span><i class="bi bi-cart-fill me-3"></i>Ordini</span>
                        <i class="bi bi-chevron-right small opacity-30"></i>
                    </a>
                    <a class="nav-link d-flex align-items-center justify-content-between disabled opacity-50" style="pointer-events: none;">
                        <span><i class="bi bi-people-fill me-3"></i>Clienti</span>
                        <i class="bi bi-chevron-right small opacity-30"></i>
                    </a>
                }
            </nav>
        </div>

        <!-- Desktop Sidebar -->
        <aside class="app-sidebar d-none d-md-flex" id="desktopSidebar">
            <div class="sidebar-brand d-flex align-items-center justify-content-between text-decoration-none">
                <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none flex-grow-1" style="overflow: hidden;">
                    <div class="brand-icon bg-primary text-white d-flex align-items-center justify-content-center rounded me-3" style="width: 42px; height: 42px; font-size: 1.25rem; box-shadow: 0 4px 10px rgba(13, 110, 253, 0.3);" onclick="if(document.getElementById('desktopSidebar').classList.contains('collapsed')) { document.getElementById('sidebarToggle').click(); event.preventDefault(); }">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold text-white mb-0 sidebar-brand-text" style="letter-spacing: 0.5px;">BoxManager</h5>
                        <small class="text-muted text-uppercase sidebar-brand-subtext" style="font-size: 0.65rem; letter-spacing: 1px; font-weight: 600;">Gestionale Scatole</small>
                    </div>
                </a>
                <button id="sidebarToggle" class="btn text-white-50 p-1 ms-1 hover-white shadow-none" title="Riduci menu">
                    <i class="bi bi-layout-sidebar"></i>
                </button>
            </div>
            
            <div class="sidebar-nav">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <a class="nav-link d-flex align-items-center justify-content-between @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() != "Settings" ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <div class="d-flex align-items-center"><i class="bi bi-grid-fill me-3"></i><span class="nav-text">Dashboard</span></div>
                        <i class="bi bi-chevron-right small opacity-50"></i>
                    </a>
                    
                    if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link d-flex align-items-center justify-content-between @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Customers" ? "active" : "")" asp-controller="Customers" asp-action="Index">
                            <div class="d-flex align-items-center"><i class="bi bi-people-fill me-3"></i><span class="nav-text">Clienti</span></div>
                            <i class="bi bi-chevron-right small opacity-50"></i>
                        </a>
                    }
                    <a class="nav-link d-flex align-items-center justify-content-between @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Orders" ? "active" : "")" asp-controller="Orders" asp-action="Index">
                        <div class="d-flex align-items-center"><i class="bi bi-cart-fill me-3"></i><span class="nav-text">Ordini</span></div>
                        <span class="d-flex align-items-center">
                            @if (pendingOrdersCount > 0)
                            {
                                <span class="badge bg-warning text-dark me-2">@pendingOrdersCount</span>
                            }
                            <i class="bi bi-chevron-right small opacity-50"></i>
                        </span>
                    </a>
                    <a class="nav-link d-flex align-items-center justify-content-between @(ViewContext.RouteData.Values["Action"]?.ToString() == "Settings" ? "active" : "")" asp-controller="Home" asp-action="Settings">
                        <div class="d-flex align-items-center"><i class="bi bi-gear-fill me-3"></i><span class="nav-text">Impostazioni</span></div>
                        <i class="bi bi-chevron-right small opacity-50"></i>
                    </a>
                }
                else
                {
                    <a class="nav-link d-flex align-items-center justify-content-between disabled opacity-50 mb-2" style="pointer-events: none;">
                        <div class="d-flex align-items-center"><i class="bi bi-grid-fill me-3"></i><span class="nav-text">Dashboard</span></div>
                        <i class="bi bi-chevron-right small opacity-30"></i>
                    </a>
                    <a class="nav-link d-flex align-items-center justify-content-between disabled opacity-50 mb-2" style="pointer-events: none;">
                        <div class="d-flex align-items-center"><i class="bi bi-cart-fill me-3"></i><span class="nav-text">Ordini</span></div>
                        <i class="bi bi-chevron-right small opacity-30"></i>
                    </a>
                    <a class="nav-link d-flex align-items-center justify-content-between disabled opacity-50 mb-2" style="pointer-events: none;">
                        <div class="d-flex align-items-center"><i class="bi bi-people-fill me-3"></i><span class="nav-text">Clienti</span></div>
                        <i class="bi bi-chevron-right small opacity-30"></i>
                    </a>
                }
            </div>
            
            <div class="sidebar-profile">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <div class="avatar" title="@User.Identity?.Name">@userInitials</div>
                    <div class="flex-grow-1 overflow-hidden me-2 profile-details ms-2">
                        <div class="fw-bold text-white text-truncate" style="font-size: 0.85rem;" title="@User.Identity?.Name">@User.Identity?.Name</div>
                        <div class="text-muted" style="font-size: 0.75rem;">@userRoleDisplayName</div>
                    </div>
                    <a class="btn p-0 text-white-50 hover-white me-3 theme-toggle-btn" title="Cambia Tema">
                        <i class="bi bi-moon fs-5"></i>
                    </a>
                    <a class="btn p-0 text-white-50 hover-white logout-btn" asp-controller="Account" asp-action="Logout" title="Disconnetti">
                        <i class="bi bi-box-arrow-left fs-5"></i>
                    </a>
                }
                else
                {
                    <div class="avatar opacity-50 bg-secondary">--</div>
                    <div class="ms-2 profile-details">
                        <div class="fw-bold text-white opacity-50" style="font-size: 0.85rem;">Non Connesso</div>
                        <div class="text-muted opacity-50" style="font-size: 0.75rem;">Accedi per continuare</div>
                    </div>
                    <div class="ms-auto theme-toggle-btn">
                        <a class="btn p-0 text-white-50 hover-white" title="Cambia Tema">
                            <i class="bi bi-moon fs-5"></i>
                        </a>
                    </div>
                }
            </div>
        </aside>
        <script>
            if (localStorage.getItem('sidebar_collapsed') === 'true') {
                document.getElementById('desktopSidebar').classList.add('collapsed');
            }
        </script>

        <!-- Main Content Area -->
        <div class="main-content">
            <main role="main" class="content-body">
                @RenderBody()
            </main>
            <footer class="border-top footer text-muted bg-white py-3 px-4 mt-auto">
                <div class="container-fluid p-0">
                    &copy; 2026 - <strong>BoxManager</strong> - Progetto Laboratorio IUM - Unibo Cesena - Niki Hammond & Silvia Busti
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var toggles = document.querySelectorAll('.theme-toggle-btn');
            function updateIcons() {
                var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                toggles.forEach(function(toggle) {
                    var icon = toggle.querySelector('i');
                    if(icon) {
                        if(isDark) {
                            icon.classList.remove('bi-moon');
                            icon.classList.add('bi-sun');
                        } else {
                            icon.classList.remove('bi-sun');
                            icon.classList.add('bi-moon');
                        }
                    }
                });
                
                // Sync settings page switch if present
                var settingsToggle = document.getElementById('darkModeSwitch');
                if (settingsToggle) {
                    settingsToggle.checked = isDark;
                }
            }
            updateIcons();
            
            function toggleTheme() {
                if(document.documentElement.getAttribute('data-theme') === 'dark') {
                    document.documentElement.removeAttribute('data-theme');
                    localStorage.setItem('theme', 'light');
                } else {
                    document.documentElement.setAttribute('data-theme', 'dark');
                    localStorage.setItem('theme', 'dark');
                }
                updateIcons();
            }

            toggles.forEach(function(toggle) {
                toggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    toggleTheme();
                });
            });

            // Gestione pagina settings toggle
            var settingsToggle = document.getElementById('darkModeSwitch');
            if (settingsToggle) {
                settingsToggle.addEventListener('change', function(e) {
                    toggleTheme();
                });
            }

            // Gestione Sidebar Toggle
            var sidebarToggleBtn = document.getElementById('sidebarToggle');
            var sidebar = document.getElementById('desktopSidebar');
            if (sidebarToggleBtn && sidebar) {
                sidebarToggleBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    sidebar.classList.toggle('collapsed');
                    localStorage.setItem('sidebar_collapsed', sidebar.classList.contains('collapsed'));
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
