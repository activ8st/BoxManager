@model BoxManager.Models.Customer
@{
    ViewData["Title"] = "Scheda Cliente";
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a asp-action="Index">Clienti</a></li>
    <li class="breadcrumb-item active" aria-current="page">@Model.BusinessName</li>
  </ol>
</nav>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Informazioni Cliente</h5>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-light"><i class="bi bi-pencil"></i></a>
            </div>
            <div class="card-body">
                <p><strong>Ragione Sociale:</strong><br />@Model.BusinessName</p>
                <p><strong>P.IVA:</strong><br />@Model.VatNumber</p>
                <p><strong>Indirizzo:</strong><br />@Model.Address</p>
                <p><strong>Email:</strong><br />@Model.Email</p>
                <p><strong>Telefono:</strong><br />@Model.Phone</p>
                <p><strong>Referente:</strong><br />@Model.ContactPerson</p>
                <p><strong>Note:</strong><br />@(string.IsNullOrEmpty(Model.Notes) ? "Nessuna nota" : Model.Notes)</p>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <!-- Dashboard Riassuntiva Cliente -->
        <div class="row g-3 mb-4">
            <div class="col-xl-4 col-md-6">
                <div class="card bg-primary text-white border-0 shadow-sm rounded-4 h-100 overflow-hidden position-relative">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div style="z-index: 1; position: relative;">
                                <h6 class="text-white-50 mb-1 fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.75rem;">Totale Speso</h6>
                                <h3 class="mb-0 fw-bold">€ @Model.Orders.Where(o => o.Status == BoxManager.Models.OrderStatus.Completed || o.Status == BoxManager.Models.OrderStatus.Delivered).Sum(o => o.TotalPrice).ToString("N2")</h3>
                            </div>
                            <div class="p-2 bg-white bg-opacity-25 rounded-3" style="z-index: 1; position: relative;">
                                <i class="bi bi-wallet2 fs-5"></i>
                            </div>
                        </div>
                        <p class="mb-0 text-white-50 small" style="z-index: 1; position: relative;"><i class="bi bi-check-circle me-1"></i>Ordini completati</p>
                    </div>
                    <div class="position-absolute" style="bottom: -15px; right: -15px; opacity: 0.15; transform: scale(2.5); z-index: 0;">
                        <i class="bi bi-wallet2"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-xl-4 col-md-6">
                <div class="card bg-warning text-dark border-0 shadow-sm rounded-4 h-100 overflow-hidden position-relative">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div style="z-index: 1; position: relative;">
                                <h6 class="text-dark-50 mb-1 fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.75rem;">In Lavorazione</h6>
                                <h3 class="mb-0 fw-bold">@Model.Orders.Count(o => o.Status == BoxManager.Models.OrderStatus.Pending || o.Status == BoxManager.Models.OrderStatus.InProduction)</h3>
                            </div>
                            <div class="p-2 bg-dark bg-opacity-10 rounded-3" style="z-index: 1; position: relative;">
                                <i class="bi bi-box-seam fs-5"></i>
                            </div>
                        </div>
                        <p class="mb-0 text-dark-50 small" style="opacity: 0.8; z-index: 1; position: relative;"><i class="bi bi-clock-history me-1"></i>In attesa di consegna</p>
                    </div>
                    <div class="position-absolute" style="bottom: -15px; right: -15px; opacity: 0.08; transform: scale(2.5); z-index: 0;">
                        <i class="bi bi-box-seam"></i>
                    </div>
                </div>
            </div>
            
            <div class="col-xl-4 col-md-12">
                <div class="card bg-success text-white border-0 shadow-sm rounded-4 h-100 overflow-hidden position-relative">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div style="z-index: 1; position: relative;">
                                <h6 class="text-white-50 mb-1 fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.75rem;">Totale Ordini</h6>
                                <h3 class="mb-0 fw-bold">@Model.Orders.Count()</h3>
                            </div>
                            <div class="p-2 bg-white bg-opacity-25 rounded-3" style="z-index: 1; position: relative;">
                                <i class="bi bi-graph-up-arrow fs-5"></i>
                            </div>
                        </div>
                        <p class="mb-0 text-white-50 small" style="z-index: 1; position: relative;"><i class="bi bi-activity me-1"></i>Volume complessivo</p>
                    </div>
                    <div class="position-absolute" style="bottom: -15px; right: -15px; opacity: 0.15; transform: scale(2.5); z-index: 0;">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm rounded-4 border-0">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center rounded-top-4">
                <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-list-ul me-2 text-primary"></i>Storico Ordini</h5>
                <a asp-controller="Orders" asp-action="Create" asp-route-customerId="@Model.Id" class="btn btn-sm btn-primary">+ Nuovo Ordine</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Data</th>
                                <th>Codice</th>
                                <th>Quantità</th>
                                <th>Stato</th>
                                <th>Totale</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders.OrderByDescending(o => o.OrderDate))
                            {
                                <tr>
                                    <td>#@order.Id</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td>@order.BoxCode</td>
                                    <td>@order.Quantity</td>
                                    <td>
                                        <span class="badge rounded-pill @(order.Status == BoxManager.Models.OrderStatus.Completed ? "bg-success" : (order.Status == BoxManager.Models.OrderStatus.InProduction || order.Status == BoxManager.Models.OrderStatus.Pending ? "badge-gray" : "bg-warning text-dark"))">
                                            @order.Status
                                        </span>
                                    </td>
                                    <td>€ @order.TotalPrice.ToString("N2")</td>
                                    <td>
                                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-link">Dettagli</a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Orders.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">Nessun ordine trovato per questo cliente.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
