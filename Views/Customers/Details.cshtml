@model BoxManager.Models.Customer
@{
    ViewData["Title"] = "Scheda Cliente";
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a asp-action="Index">Clienti</a></li>
    <li class="breadcrumb-item active" aria-current="page">@Model.BusinessName</li>
  </ol>
</nav>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Informazioni Cliente</h5>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="text-muted small text-decoration-none">
                    <i class="bi bi-pencil me-1"></i>Modifica
                </a>
            </div>
            <style>
                .info-label { font-size: 0.75rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.2rem; }
                .info-value { font-size: 0.95rem; color: #374151; font-weight: 500; margin-bottom: 1.25rem; }
            </style>
            <div class="card-body p-4">
                <div class="row">
                    <div class="col-sm-6">
                        <div class="info-label"><i class="bi bi-building me-1"></i> Ragione Sociale</div>
                        <div class="info-value">@Model.BusinessName</div>

                        <div class="info-label"><i class="bi bi-person me-1"></i> Referente</div>
                        <div class="info-value">@Model.ContactPerson</div>
                        
                        <div class="info-label"><i class="bi bi-geo-alt me-1"></i> Indirizzo</div>
                        <div class="info-value mb-sm-0">@Model.Address</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="info-label"><i class="bi bi-card-text me-1"></i> P.IVA</div>
                        <div class="info-value">@Model.VatNumber</div>

                        <div class="info-label"><i class="bi bi-envelope me-1"></i> Email</div>
                        <div class="info-value">@Model.Email</div>
                        
                        <div class="info-label"><i class="bi bi-telephone me-1"></i> Telefono</div>
                        <div class="info-value mb-sm-0">@Model.Phone</div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="mt-4 pt-3 border-top">
                        <div class="info-label"><i class="bi bi-sticky me-1"></i> Note</div>
                        <div class="info-value mb-0">@Model.Notes</div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <!-- Dashboard Riassuntiva Cliente -->
        <div class="row g-3 mb-4">
            <div class="col-xl-4 col-md-6">
                <div class="card bg-light text-dark border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h6 class="text-dark-50 mb-1 fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.75rem;">Totale Speso</h6>
                        <h3 class="mb-3 fw-bold" style="font-size: clamp(1rem, 2.5vw, 1.75rem); white-space: nowrap;">€ @Model.Orders.Where(o => o.Status == BoxManager.Models.OrderStatus.Completed || o.Status == BoxManager.Models.OrderStatus.Delivered).Sum(o => o.TotalPrice).ToString("N2")</h3>
                        <p class="mb-0 text-dark-50 small"><i class="bi bi-check-circle me-1"></i>Ordini completati</p>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="card bg-light text-dark border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h6 class="text-dark-50 mb-1 fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.75rem;">In Lavorazione</h6>
                        <h3 class="mb-3 fw-bold" style="font-size: clamp(1rem, 2.5vw, 1.75rem); white-space: nowrap;">@Model.Orders.Count(o => o.Status == BoxManager.Models.OrderStatus.Pending || o.Status == BoxManager.Models.OrderStatus.InProduction)</h3>
                        <p class="mb-0 text-dark-50 small"><i class="bi bi-clock-history me-1"></i>In attesa di consegna</p>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-md-12">
                <div class="card bg-light text-dark border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h6 class="text-dark-50 mb-1 fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.75rem;">Totale Ordini</h6>
                        <h3 class="mb-3 fw-bold" style="font-size: clamp(1rem, 2.5vw, 1.75rem); white-space: nowrap;">@Model.Orders.Count()</h3>
                        <p class="mb-0 text-dark-50 small"><i class="bi bi-activity me-1"></i>Volume complessivo</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm rounded-4 border-0">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center rounded-top-4">
                <h5 class="mb-0 fw-bold text-dark">Storico Ordini</h5>
                <a asp-controller="Orders" asp-action="Create" asp-route-customerId="@Model.Id" class="btn btn-primary">+ Nuovo Ordine</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Data</th>
                                <th>Codice</th>
                                <th>Quantità</th>
                                <th>Stato</th>
                                <th style="text-align:right; white-space:nowrap;">Totale</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders.OrderByDescending(o => o.OrderDate))
                            {
                                <tr style="cursor:pointer;" onclick="window.location.href='@Url.Action("Details", "Orders", new { id = order.Id })'">
                                    <td>#@order.Id</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td>@order.BoxCode</td>
                                    <td>@order.Quantity</td>
                                    <td>
                                        <span class="badge rounded-pill @(order.Status == BoxManager.Models.OrderStatus.Delivered ? "bg-primary text-white" : "bg-secondary")">
                                            @(order.Status switch
                                            {
                                                BoxManager.Models.OrderStatus.Pending => "In attesa",
                                                BoxManager.Models.OrderStatus.InProduction => "In produzione",
                                                BoxManager.Models.OrderStatus.Completed => "Completato",
                                                BoxManager.Models.OrderStatus.Delivered => "Consegnato",
                                                BoxManager.Models.OrderStatus.Cancelled => "Annullato",
                                                _ => order.Status.ToString()
                                            })
                                        </span>
                                    </td>
                                    <td style="text-align:right; white-space:nowrap;">€ @order.TotalPrice.ToString("N2")</td>
                                    <td></td>
                                </tr>
                            }
                            @if (!Model.Orders.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">Nessun ordine trovato per questo cliente.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
