@model IEnumerable<BoxManager.Models.Customer>
@{
    ViewData["Title"] = "Gestione Clienti";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Gestione Clienti</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus me-2"></i>Nuovo Cliente</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="get" class="mb-4">
            <div class="input-group">
                <input type="text" name="searchString" class="form-control" placeholder="Cerca per ragione sociale o P.IVA..." value="@ViewData["CurrentFilter"]">
                <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search me-2"></i>Cerca</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Ragione Sociale</th>
                        <th>P.IVA</th>
                        <th>Email</th>
                        <th>Telefono</th>
                        <th>Referente</th>
                        <th class="text-end">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.BusinessName</td>
                            <td>@item.VatNumber</td>
                            <td>@item.Email</td>
                            <td>@item.Phone</td>
                            <td>@item.ContactPerson</td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Dettagli"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Modifica"><i class="bi bi-pencil"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
