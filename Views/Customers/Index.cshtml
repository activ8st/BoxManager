@model IEnumerable<BoxManager.Models.Customer>
@{
    ViewData["Title"] = "Gestione Clienti";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Gestione Clienti</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus me-2"></i>Nuovo Cliente</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="get" class="mb-4">
            <div class="position-relative">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="pointer-events:none;"></i>
                <input type="text" name="searchString" class="form-control ps-5" placeholder="Cerca per ragione sociale o P.IVA..." value="@ViewData["CurrentFilter"]">
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr class="text-muted" style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px;">
                        <th class="ps-4">Ragione Sociale</th>
                        <th>P.IVA</th>
                        <th>Email</th>
                        <th>Telefono</th>
                        <th>Referente</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="cursor:pointer;" onclick="window.location.href='@Url.Action("Details", "Customers", new { id = item.Id })'">
                            <td class="ps-4 fw-bold text-dark">@item.BusinessName</td>
                            <td class="text-muted" style="font-size: 0.85rem;">@item.VatNumber</td>
                            <td class="text-muted" style="font-size: 0.85rem;">@item.Email</td>
                            <td class="text-muted" style="font-size: 0.85rem; white-space:nowrap;">@item.Phone</td>
                            <td class="text-muted" style="font-size: 0.85rem;">@item.ContactPerson</td>
                            <td class="text-end pe-3">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-light border"
                                   style="border-radius: 0.375rem; padding: 0.2rem 0.5rem;"
                                   onclick="event.stopPropagation();">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
