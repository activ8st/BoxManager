@model BoxManager.Models.Customer
@{
    ViewData["Title"] = User.IsInRole("Customer") ? "Modifica Profilo" : "Modifica Cliente";
    var formAction = User.IsInRole("Customer") ? "EditProfile" : "Edit";
    var cancelUrl = User.IsInRole("Customer") ? Url.Action("Index", "Home") : Url.Action("Details", new { id = Model.Id });
}

<div class="container">
    <h2 class="fw-bold mb-4">@ViewData["Title"]</h2>

    <form asp-action="@formAction" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row">
            <div class="col-md-12 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Informazioni Cliente</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">

                            <!-- Ragione Sociale: sempre sola lettura -->
                            <div class="col-md-12 mb-3">
                                <label asp-for="BusinessName" class="form-label">Ragione Sociale</label>
                                <input asp-for="BusinessName" class="form-control bg-light" disabled="disabled" />
                                <input type="hidden" asp-for="BusinessName" />
                                <span asp-validation-for="BusinessName" class="text-danger small"></span>
                            </div>

                            <!-- P.IVA: sempre sola lettura -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="VatNumber" class="form-label">Partita IVA</label>
                                <input asp-for="VatNumber" class="form-control bg-light" disabled="disabled" />
                                <input type="hidden" asp-for="VatNumber" />
                                <span asp-validation-for="VatNumber" class="text-danger small"></span>
                            </div>

                            <!-- Referente: modificabile -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="ContactPerson" class="form-label">Referente</label>
                                <input asp-for="ContactPerson" class="form-control" />
                                <span asp-validation-for="ContactPerson" class="text-danger small"></span>
                            </div>

                            <!-- Email: modificabile -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label">Email</label>
                                <input asp-for="Email" class="form-control" type="email" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <!-- Telefono: modificabile -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label">Telefono</label>
                                <input asp-for="Phone" class="form-control" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>

                            <!-- Indirizzo: sempre sola lettura -->
                            <div class="col-md-12 mb-3">
                                <label asp-for="Address" class="form-label">Indirizzo</label>
                                <input asp-for="Address" class="form-control bg-light" disabled="disabled" />
                                <input type="hidden" asp-for="Address" />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>

                            <!-- Note: modificabile -->
                            <div class="col-md-12 mb-0">
                                <label asp-for="Notes" class="form-label">Note</label>
                                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Notes" class="text-danger small"></span>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mb-5">
            <a href="@cancelUrl" class="btn btn-outline-secondary">Annulla</a>
            <button type="submit" class="btn px-5" style="background-color: #0d6efd; color: #fff; border: none;">Salva</button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
